# Environment variables for SurplusX

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=surplusx

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d

# API Gateway
API_PORT=3000

# Services
AUTH_SERVICE_PORT=3001
FOOD_SERVICE_PORT=3002
MATCHING_SERVICE_PORT=3003
DELIVERY_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
METRICS_SERVICE_PORT=3006
AI_SERVICE_PORT=3007
REALTIME_SERVICE_PORT=3008

# AI Service
AI_MODEL_PATH=./data/models

# Notification Service
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Map Service
GOOGLE_MAPS_API_KEY=your_google_maps_key